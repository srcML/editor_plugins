{
    "name": "srcslice-extension",
    "displayName": "srcSlice Extension",
    "description": "Uses srcSlice, a fast lightweight srcML tool for static slicing, for visualizing slices",
    "publisher":"srcML",
    "icon":"resources/extension-icon.png",
    "version": "0.0.1",
    "license": "GPL-3.0",
    "engines": {
        "vscode": "^1.104.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [ "onStartupFinished" ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "srcSlice-extension",
                    "title": "srcSlice",
                    "icon": "resources/srcml-logo.svg"
                }
            ]
        },
        "views": {
            "srcSlice-extension": [
                {
                    "type": "webview",
                    "id": "srcSlice-viewer",
                    "name": "srcSlice Panel",
                    "icon": "resources/srcml-logo.svg"
                }
            ]
        },
        "commands": [
            {
                "command": "srcslice-extension.findSlice",
                "title": "Find Slice"
            },
            {
                "command": "srcslice-extension.hideSlice",
                "title": "Hide Slice"
            },
            {
                "command": "srcslice-extension.getEditorSlices",
                "title": "Get slices from editors"
            },
            {
                "command": "srcslice-extension.getAllSlices",
                "title": "Get all Slices within the workspace"
            }
        ],
        "keybindings": [
            {
                "command": "srcslice-extension.findSlice",
                "key": "ctrl+alt+f",
                "mac": "cmd+alt+f",
                "when": "editorTextFocus"
            },
            {
                "command": "srcslice-extension.hideSlice",
                "key": "ctrl+alt+h",
                "mac": "cmd+alt+h",
                "when": "editorTextFocus"
            },
            {
                "command": "srcslice-extension.getEditorSlices",
                "key": "ctrl+alt+e",
                "mac": "cmd+alt+e"
            },
            {
                "command": "srcslice-extension.getAllSlices",
                "key": "ctrl+alt+a",
                "mac": "cmd+alt+a"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "srcslice-extension.findSlice",
                    "when": "editorHasSelection",
                    "group": "navigation"
                },
                {
                    "command": "srcslice-extension.hideSlice",
                    "when": "editorHasSelection",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.104.0",
        "@types/xml2js": "^0.4.14",
        "@typescript-eslint/eslint-plugin": "^8.42.0",
        "@typescript-eslint/parser": "^8.42.0",
        "@vscode/test-cli": "^0.0.11",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.34.0",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "xml2js": "^0.6.2"
    }
}
