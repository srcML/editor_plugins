{
    "name": "srcslice-extension",
    "displayName": "srcSlice Extension",
    "description": "Uses srcSlice, a fast lightweight srcML tool for static slicing, for visualizing slices",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.104.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "srcslice-extension.findSlice",
                "title": "Find Slice"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "srcslice-extension.findSlice",
                    "when": "editorHasSelection",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.104.0",
        "@typescript-eslint/eslint-plugin": "^8.42.0",
        "@typescript-eslint/parser": "^8.42.0",
        "@vscode/test-cli": "^0.0.11",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.34.0",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "xml2js": "^0.6.2"
    }
}
