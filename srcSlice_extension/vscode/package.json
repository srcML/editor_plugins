{
    "name": "slice-inspector",
    "displayName": "Slice Inspector",
    "description": "Uses srcSlice, a fast lightweight srcML tool for static slicing, for visualizing slices",
    "publisher": "srcML",
    "icon": "resources/extension-icon.png",
    "version": "0.0.1",
    "license": "GPL-3.0",
    "engines": {
        "vscode": "^1.104.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "slice-inspector",
                    "title": "Slice Inspector",
                    "icon": "resources/srcml-logo.svg"
                }
            ]
        },
        "views": {
            "slice-inspector": [
                {
                    "type": "webview",
                    "id": "slice-viewer",
                    "name": "",
                    "icon": "resources/srcml-logo.svg"
                }
            ]
        },
        "commands": [
            {
                "command": "slice-inspector.findSlice",
                "title": "Find Slice"
            },
            {
                "command": "slice-inspector.hideSlice",
                "title": "Hide Slice"
            },
            
            {
                "command": "slice-inspector.findSlices",
                "title": "Inspect Selection"
            },
            {
                "command": "slice-inspector.hideSlices",
                "title": "Disregard Selection"
            },

            {
                "command": "slice-inspector.getEditorSlices",
                "title": "Get slices from Editors"
            },
            {
                "command": "slice-inspector.getAllSlices",
                "title": "Get slices from Workspace"
            }
        ],
        "keybindings": [
            {
                "command": "slice-inspector.findSlice",
                "key": "ctrl+alt+f",
                "mac": "cmd+alt+f",
                "when": "slice-inspector.isWordSelection"
            },
            {
                "command": "slice-inspector.hideSlice",
                "key": "ctrl+alt+h",
                "mac": "cmd+alt+h",
                "when": "slice-inspector.isWordSelection"
            },

            {
                "command": "slice-inspector.findSlices",
                "key": "ctrl+shift+alt+f",
                "mac": "cmd+shift+alt+f",
                "when": "slice-inspector.isMultiLineSelection"
            },
            {
                "command": "slice-inspector.hideSlices",
                "key": "ctrl+shift+alt+h",
                "mac": "cmd+shift+alt+h",
                "when": "slice-inspector.isMultiLineSelection"
            },

            {
                "command": "slice-inspector.filterOff",
                "key": "ctrl+alt+l",
                "mac": "cmd+alt+l"
            },
            {
                "command": "slice-inspector.filterOn",
                "key": "ctrl+alt+k",
                "mac": "cmd+alt+k"
            },

            {
                "command": "slice-inspector.getEditorSlices",
                "key": "ctrl+alt+e",
                "mac": "cmd+alt+e"
            },
            {
                "command": "slice-inspector.getAllSlices",
                "key": "ctrl+alt+a",
                "mac": "cmd+alt+a"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "slice-inspector.getEditorSlices",
                    "group": "navigation"
                },
                {
                    "command": "slice-inspector.getAllSlices",
                    "group": "navigation"
                },
                {
                    "command": "slice-inspector.findSlice",
                    "when": "slice-inspector.isWordSelection",
                    "group": "navigation"
                },
                {
                    "command": "slice-inspector.hideSlice",
                    "when": "slice-inspector.isWordSelection",
                    "group": "navigation"
                },
                {
                    "command": "slice-inspector.findSlices",
                    "when": "slice-inspector.isMultiLineSelection",
                    "group": "navigation"
                },
                {
                    "command": "slice-inspector.hideSlices",
                    "when": "slice-inspector.isMultiLineSelection",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.104.0",
        "@types/xml2js": "^0.4.14",
        "@typescript-eslint/eslint-plugin": "^8.42.0",
        "@typescript-eslint/parser": "^8.42.0",
        "@vscode/test-cli": "^0.0.11",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.34.0",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "@xmldom/xmldom": "^0.9.10",
        "xml2js": "^0.6.2",
        "xpath": "^0.0.34"
    }
}
